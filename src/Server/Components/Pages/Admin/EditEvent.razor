@page "/admin/events/edit/{EventId:int}"
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]

@inject EventService EventService
@inject AuditService AuditService
@inject NavigationManager Nav

<PageTitle>Edit Event</PageTitle>

@if (evt is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h1 class="card-title">Edit Event</h1>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
            }

            <EditForm Model="model" OnValidSubmit="SaveAsync" FormName="editEvent">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="model.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" rows="5" @bind-Value="model.Description" />
                    <div class="form-text">Basic HTML is allowed: links, bold, italic, and lists.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <InputText class="form-control" @bind-Value="model.Location" />
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Date</label>
                        <InputDate class="form-control" @bind-Value="model.Date" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Time</label>
                        <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="model.Time" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Duration (hours)</label>
                        <InputNumber class="form-control" @bind-Value="model.DurationHours" />
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="model.IsPublic" />
                    <label class="form-check-label">Public event (visible on home page)</label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="model.RequiresRsvp" />
                    <label class="form-check-label">Require RSVP</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/events" class="btn btn-secondary ms-2">Back</a>
            </EditForm>
        </div>
    </div>

    @if (evt.RequiresRsvp && evt.Rsvps.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">RSVPs (@evt.Rsvps.Count)</h5>
                <ul class="list-group">
                    @foreach (var rsvp in evt.Rsvps.OrderBy(r => r.User.FullName))
                    {
                        <li class="list-group-item">@rsvp.User.FullName (@rsvp.User.Email)</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" @formname="deleteEvent" @onsubmit="DeleteAsync">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this event?');">Delete Event</button>
            </form>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [Parameter] public int EventId { get; set; }

    private Event? evt;
    [SupplyParameterFromForm]
    private EventModel model { get; set; } = default!;
    private string? message;
    private bool isError;

    protected override async Task OnInitializedAsync()
    {
        evt = await EventService.GetByIdAsync(EventId);
        if (evt is null) return;

        model ??= new EventModel
        {
            Name = evt.Name,
            Description = evt.Description,
            Date = evt.Date.Date,
            Time = DateTime.Today.Add(evt.Date.TimeOfDay),
            DurationHours = evt.Duration.TotalHours,
            Location = evt.Location,
            IsPublic = evt.IsPublic,
            RequiresRsvp = evt.RequiresRsvp
        };
    }

    private async Task SaveAsync()
    {
        if (evt is null) return;

        var dateTime = model.Date.Add(model.Time.TimeOfDay);
        var duration = TimeSpan.FromHours(model.DurationHours);

        await EventService.UpdateAsync(evt, model.Name, model.Description, dateTime, duration, model.Location, model.IsPublic, model.RequiresRsvp);

        var actorEmail = HttpContext.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";
        var ip = HttpContext.Connection.RemoteIpAddress?.ToString();
        await AuditService.LogAsync(AuditAction.EditEvent, actorEmail, ip, new Dictionary<string, string>
        {
            ["EventName"] = model.Name,
            ["EventId"] = EventId.ToString()
        });

        message = "Event updated.";
        isError = false;
    }

    private async Task DeleteAsync()
    {
        if (evt is null) return;

        var actorEmail = HttpContext.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";
        var ip = HttpContext.Connection.RemoteIpAddress?.ToString();
        await AuditService.LogAsync(AuditAction.DeleteEvent, actorEmail, ip, new Dictionary<string, string>
        {
            ["EventName"] = evt.Name,
            ["EventId"] = EventId.ToString()
        });

        await EventService.DeleteAsync(EventId);
        Nav.NavigateTo("/admin/events");
    }

    private sealed class EventModel
    {
        [Required]
        public string Name { get; set; } = "";

        [Required]
        public string Description { get; set; } = "";

        public DateTime Date { get; set; }

        public DateTime Time { get; set; }

        [Required]
        [Range(0.25, 72, ErrorMessage = "Duration must be between 15 minutes and 72 hours.")]
        public double DurationHours { get; set; } = 1;

        public string? Location { get; set; }
        public bool IsPublic { get; set; }
        public bool RequiresRsvp { get; set; }
    }
}
