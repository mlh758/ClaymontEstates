@page "/admin/events/edit/{EventId:int}"
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject EventService EventService
@inject AuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Edit Event</PageTitle>

@if (evt is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h1 class="card-title">Edit Event</h1>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
            }

            <EditForm Model="model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label" for="event-name">Name</label>
                    <InputText id="event-name" class="form-control" @bind-Value="model.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <RadzenHtmlEditor @bind-Value="model.Description" style="height: 250px;">
                        <RadzenHtmlEditorUndo />
                        <RadzenHtmlEditorRedo />
                        <RadzenHtmlEditorSeparator />
                        <RadzenHtmlEditorBold />
                        <RadzenHtmlEditorItalic />
                        <RadzenHtmlEditorUnderline />
                        <RadzenHtmlEditorStrikeThrough />
                        <RadzenHtmlEditorSeparator />
                        <RadzenHtmlEditorUnorderedList />
                        <RadzenHtmlEditorOrderedList />
                        <RadzenHtmlEditorSeparator />
                        <RadzenHtmlEditorColor />
                        <RadzenHtmlEditorSeparator />
                        <RadzenHtmlEditorLink />
                        <RadzenHtmlEditorUnlink />
                        <RadzenHtmlEditorSeparator />
                        <RadzenHtmlEditorSource />
                    </RadzenHtmlEditor>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="event-location">Location</label>
                    <InputText id="event-location" class="form-control" @bind-Value="model.Location" />
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label" for="event-date">Date</label>
                        <InputDate id="event-date" class="form-control" @bind-Value="model.Date" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="event-time">Time</label>
                        <InputDate id="event-time" Type="InputDateType.Time" class="form-control" @bind-Value="model.Time" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="event-duration">Duration (hours)</label>
                        <InputNumber id="event-duration" class="form-control" @bind-Value="model.DurationHours" />
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="event-public" class="form-check-input" @bind-Value="model.IsPublic" />
                    <label class="form-check-label" for="event-public">Public event (visible on home page)</label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="event-rsvp" class="form-check-input" @bind-Value="model.RequiresRsvp" />
                    <label class="form-check-label" for="event-rsvp">Require RSVP</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/events" class="btn btn-secondary ms-2">Back</a>
            </EditForm>
        </div>
    </div>

    @if (evt.RequiresRsvp && evt.Rsvps.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">RSVPs (@evt.Rsvps.Count)</h5>
                <ul class="list-group">
                    @foreach (var rsvp in evt.Rsvps.OrderBy(r => r.User.FullName))
                    {
                        <li class="list-group-item">@rsvp.User.FullName (@rsvp.User.Email)</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Delete Event</button>
        </div>
    </div>
}

@code {
    [Parameter] public int EventId { get; set; }

    private Event? evt;
    private EventModel model = new();
    private string? message;
    private bool isError;

    protected override async Task OnInitializedAsync()
    {
        evt = await EventService.GetByIdAsync(EventId);
        if (evt is null) return;

        model = new EventModel
        {
            Name = evt.Name,
            Description = evt.Description,
            Date = evt.Date.Date,
            Time = DateTime.Today.Add(evt.Date.TimeOfDay),
            DurationHours = evt.Duration.TotalHours,
            Location = evt.Location,
            IsPublic = evt.IsPublic,
            RequiresRsvp = evt.RequiresRsvp
        };
    }

    private async Task SaveAsync()
    {
        if (evt is null) return;

        var dateTime = model.Date.Add(model.Time.TimeOfDay);
        var duration = TimeSpan.FromHours(model.DurationHours);

        await EventService.UpdateAsync(evt, model.Name, model.Description ?? "", dateTime, duration, model.Location, model.IsPublic, model.RequiresRsvp);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";
        await AuditService.LogAsync(AuditAction.EditEvent, actorEmail, null, new Dictionary<string, string>
        {
            ["EventName"] = model.Name,
            ["EventId"] = EventId.ToString()
        });

        message = "Event updated.";
        isError = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (evt is null) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";
        await AuditService.LogAsync(AuditAction.DeleteEvent, actorEmail, null, new Dictionary<string, string>
        {
            ["EventName"] = evt.Name,
            ["EventId"] = EventId.ToString()
        });

        await EventService.DeleteAsync(EventId);
        Nav.NavigateTo("/admin/events");
    }

    private sealed class EventModel
    {
        [Required]
        public string Name { get; set; } = "";

        public string? Description { get; set; } = "";

        public DateTime Date { get; set; }

        public DateTime Time { get; set; }

        [Required]
        [Range(0.25, 72, ErrorMessage = "Duration must be between 15 minutes and 72 hours.")]
        public double DurationHours { get; set; } = 1;

        public string? Location { get; set; }
        public bool IsPublic { get; set; }
        public bool RequiresRsvp { get; set; }
    }
}
