@page "/admin/events/{EventId:int}/attendees"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@using Server.Components.Shared
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject EventService EventService
@inject UserService UserService

<PageTitle>Manage Attendees</PageTitle>

@if (evt is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h1 class="card-title">Attendees — @evt.Name</h1>
            <p class="text-muted mb-0">@evt.Date.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
        </div>
    </div>

    <TransferList TItem="ApplicationUser"
                  Items="allUsers"
                  ItemId="@(u => u.Id)"
                  ItemTitle="@(u => u.FullName)"
                  ItemSubtitle="@(u => u.Email)"
                  SelectedIds="attendeeUserIds"
                  OnAdd="AddAttendeeAsync"
                  OnRemove="RemoveAttendeeAsync"
                  AvailableLabel="Available Residents"
                  SelectedLabel="Attending"
                  AvailableEmptyText="Everyone is attending!"
                  SelectedEmptyText="No attendees yet." />

    <div class="mt-3">
        <a href="/admin/events/edit/@EventId" class="btn btn-secondary">Edit Event</a>
        <a href="/admin/events" class="btn btn-secondary ms-2">Manage Events</a>
    </div>
}

@code {
    [Parameter] public int EventId { get; set; }

    private Event? evt;
    private List<ApplicationUser> allUsers = [];
    private HashSet<string> attendeeUserIds = [];

    protected override async Task OnInitializedAsync()
    {
        evt = await EventService.GetByIdAsync(EventId);
        if (evt is null) return;

        allUsers = await UserService.GetAllUsersWithRolesAsync();
        attendeeUserIds = evt.Rsvps.Select(r => r.UserId).ToHashSet();
    }

    private async Task AddAttendeeAsync(ApplicationUser user)
    {
        var (success, _) = await EventService.RsvpAsync(EventId, user.Id);
        if (success)
            attendeeUserIds.Add(user.Id);
    }

    private async Task RemoveAttendeeAsync(ApplicationUser user)
    {
        var (success, _) = await EventService.CancelRsvpAsync(EventId, user.Id);
        if (success)
            attendeeUserIds.Remove(user.Id);
    }
}
