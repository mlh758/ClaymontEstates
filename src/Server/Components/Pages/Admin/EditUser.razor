@page "/admin/users/edit/{UserId}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject UserService UserService
@inject AuditService AuditService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Edit User</PageTitle>

<div class="card mb-4">
    <div class="card-body">
        <h1 class="card-title">Edit User</h1>

        @if (user is null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(message))
            {
                <RadzenAlert AlertStyle="@(isError ? AlertStyle.Danger : AlertStyle.Success)" AllowClose="false" ShowIcon="false">@message</RadzenAlert>
            }

            <EditForm Model="model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label" for="edit-fullname">Full Name</label>
                    <InputText id="edit-fullname" class="form-control" @bind-Value="model.FullName" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="edit-email">Email</label>
                    <InputText id="edit-email" type="email" class="form-control" @bind-Value="model.Email" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="edit-phone">Phone</label>
                    <InputText type="tel" id="edit-phone" class="form-control" @bind-Value="model.Phone" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Addresses</label>
                    @for (var i = 0; i < model.Addresses.Count; i++)
                    {
                        var index = i;
                        var addr = model.Addresses[index];
                        <div class="card mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="mb-2">
                                    <InputText class="form-control" placeholder="Street address" @bind-Value="addr.StreetAddress" />
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col">
                                        <InputText class="form-control" placeholder="City" @bind-Value="addr.City" />
                                    </div>
                                    <div class="col-auto" style="width: 5rem;">
                                        <InputText class="form-control" placeholder="State" @bind-Value="addr.State" />
                                    </div>
                                    <div class="col-auto" style="width: 7rem;">
                                        <InputText class="form-control" placeholder="Zip" @bind-Value="addr.Zip" />
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" id="@($"edit-private-{index}")" @bind-Value="addr.IsPrivate" />
                                        <label class="form-check-label" for="@($"edit-private-{index}")">Private (officers only)</label>
                                    </div>
                                    @if (model.Addresses.Count > 1)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => model.Addresses.RemoveAt(index)">Remove</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => model.Addresses.Add(new())">Add Address</button>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="edit-show-contact" class="form-check-input" @bind-Value="model.ShowContactInfo" />
                    <label class="form-check-label" for="edit-show-contact">Show email and phone in directory</label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="edit-wants-email" class="form-check-input" @bind-Value="model.WantsEmailNotifications" />
                    <label class="form-check-label" for="edit-wants-email">Receive community email notifications</label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Roles</label>
                    <div class="form-check">
                        <InputCheckbox id="edit-role-president" class="form-check-input" @bind-Value="model.IsPresident" />
                        <label class="form-check-label" for="edit-role-president">President</label>
                    </div>
                    <div class="form-check">
                        <InputCheckbox id="edit-role-treasurer" class="form-check-input" @bind-Value="model.IsTreasurer" />
                        <label class="form-check-label" for="edit-role-treasurer">Treasurer</label>
                    </div>
                    <div class="form-check">
                        <InputCheckbox id="edit-role-secretary" class="form-check-input" @bind-Value="model.IsSecretary" />
                        <label class="form-check-label" for="edit-role-secretary">Secretary</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/users" class="btn btn-secondary ms-2">Back</a>
            </EditForm>
        }
    </div>
</div>

@if (user is not null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Password Reset</h5>
            @if (user.LastPasswordResetSentAt is not null)
            {
                <p class="text-muted mb-1">Last password reset sent: @user.LastPasswordResetSentAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
            }
            else
            {
                <p class="text-muted mb-1">No password reset emails have been sent.</p>
            }

            <button type="button" class="btn btn-warning" @onclick="SendResetEmailAsync">Send Password Reset Email</button>

            @if (resetEmailSent)
            {
                <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false" ShowIcon="false" class="mt-3 mb-0">Password reset email sent to @user.Email.</RadzenAlert>
            }
        </div>
    </div>
}

@if (user is not null)
{
    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Delete User</h5>
            <button type="button" class="btn btn-danger" @onclick="DeleteUserAsync">
                Delete User
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string UserId { get; set; } = "";

    private ApplicationUser? user;
    private EditUserModel model = new();
    private IList<string> currentRoles = [];
    private string? message;
    private bool isError;
    private bool resetEmailSent;
    private string? actorEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";

        user = await UserService.GetUserByIdAsync(UserId);
        if (user is null) return;

        currentRoles = await UserService.GetUserRolesAsync(user);
        var addresses = await UserService.GetUserAddressesAsync(user.Id);

        model = new EditUserModel
        {
            FullName = user.FullName,
            Email = user.Email ?? "",
            Phone = user.PhoneNumber ?? "",
            Addresses = addresses.Count > 0
                ? addresses.Select(a => new AddressModel
                {
                    StreetAddress = a.StreetAddress,
                    City = a.City,
                    State = a.State,
                    Zip = a.Zip,
                    IsPrivate = a.IsPrivate
                }).ToList()
                : [new()],
            ShowContactInfo = user.ShowContactInfo,
            WantsEmailNotifications = user.WantsEmailNotifications,
            IsPresident = currentRoles.Contains(Roles.President),
            IsTreasurer = currentRoles.Contains(Roles.Treasurer),
            IsSecretary = currentRoles.Contains(Roles.Secretary)
        };
    }

    private async Task SaveAsync()
    {
        if (user is null) return;

        var (success, errors) = await UserService.UpdateUserAsync(
            user, new UserParams(
                FullName: model.FullName,
                Email: model.Email,
                Phone: model.Phone,
                Addresses: model.Addresses.Select(a => new AddressParams(a.StreetAddress, a.City, a.State, a.Zip, a.IsPrivate)).ToList(),
                ShowContactInfo: model.ShowContactInfo,
                WantsEmailNotifications: model.WantsEmailNotifications));

        if (!success)
        {
            message = string.Join(", ", errors);
            isError = true;
            return;
        }

        var newRoles = new List<string> { Roles.Resident };
        if (model.IsPresident) newRoles.Add(Roles.President);
        if (model.IsTreasurer) newRoles.Add(Roles.Treasurer);
        if (model.IsSecretary) newRoles.Add(Roles.Secretary);

        var (roleSuccess, roleErrors) = await UserService.SetUserRolesAsync(user, newRoles);
        if (!roleSuccess)
        {
            message = string.Join(", ", roleErrors);
            isError = true;
            return;
        }
        currentRoles = newRoles;

        await AuditService.LogAsync(AuditAction.EditUser, actorEmail!, null, new Dictionary<string, string>
        {
            ["TargetEmail"] = model.Email,
            ["TargetName"] = model.FullName
        });

        message = "User updated.";
        isError = false;
    }

    private async Task SendResetEmailAsync()
    {
        if (user is null) return;

        var baseUrl = Nav.BaseUri.TrimEnd('/');
        await UserService.SendPasswordResetEmailAsync(user, baseUrl);

        await AuditService.LogAsync(AuditAction.SendPasswordReset, actorEmail!, null, new Dictionary<string, string>
        {
            ["TargetEmail"] = user.Email ?? "",
            ["TargetName"] = user.FullName
        });

        resetEmailSent = true;
    }

    private async Task DeleteUserAsync()
    {
        if (user is null) return;

        var targetEmail = user.Email ?? "";
        var targetName = user.FullName;

        var (success, errors) = await UserService.DeleteUserAsync(user);
        if (!success)
        {
            message = string.Join(", ", errors);
            isError = true;
            return;
        }

        await AuditService.LogAsync(AuditAction.DeleteUser, actorEmail!, null, new Dictionary<string, string>
        {
            ["TargetEmail"] = targetEmail,
            ["TargetName"] = targetName
        });

        Nav.NavigateTo("/admin/users");
    }

    private sealed class EditUserModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FullName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        public string Phone { get; set; } = "";

        public List<AddressModel> Addresses { get; set; } = [new()];

        public bool ShowContactInfo { get; set; } = true;
        public bool WantsEmailNotifications { get; set; } = true;
        public bool IsPresident { get; set; }
        public bool IsTreasurer { get; set; }
        public bool IsSecretary { get; set; }
    }

    private sealed class AddressModel
    {
        public string StreetAddress { get; set; } = "";
        public string City { get; set; } = "";
        public string State { get; set; } = "";
        public string Zip { get; set; } = "";
        public bool IsPrivate { get; set; }
    }
}
