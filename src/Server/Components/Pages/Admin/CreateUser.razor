@page "/admin/users/create"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject UserService UserService
@inject AuditService AuditService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Create User</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Create User</h1>

        @if (created)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false" ShowIcon="false" class="mb-3">
                User created. An email has been sent with instructions to set their password.
            </RadzenAlert>
            <a href="/admin/users" class="btn btn-secondary">Back to Users</a>
        }
        else
        {
            @if (errors.Length > 0)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" ShowIcon="false">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </RadzenAlert>
            }

            <EditForm Model="model" OnValidSubmit="CreateAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <InputText class="form-control" @bind-Value="model.FullName" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText type="email" class="form-control" @bind-Value="model.Email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <InputText class="form-control" @bind-Value="model.Phone" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Addresses</label>
                    @for (var i = 0; i < model.Addresses.Count; i++)
                    {
                        var index = i;
                        var addr = model.Addresses[index];
                        <div class="card mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="mb-2">
                                    <InputText class="form-control" placeholder="Street address" @bind-Value="addr.StreetAddress" />
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col">
                                        <InputText class="form-control" placeholder="City" @bind-Value="addr.City" />
                                    </div>
                                    <div class="col-auto" style="width: 5rem;">
                                        <InputText class="form-control" placeholder="State" @bind-Value="addr.State" />
                                    </div>
                                    <div class="col-auto" style="width: 7rem;">
                                        <InputText class="form-control" placeholder="Zip" @bind-Value="addr.Zip" />
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" id="@($"create-private-{index}")" @bind-Value="addr.IsPrivate" />
                                        <label class="form-check-label" for="@($"create-private-{index}")">Private (officers only)</label>
                                    </div>
                                    @if (model.Addresses.Count > 1)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => model.Addresses.RemoveAt(index)">Remove</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => model.Addresses.Add(new())">Add Address</button>
                </div>

                <button type="submit" class="btn btn-primary">Create & Send Invite</button>
                <a href="/admin/users" class="btn btn-secondary ms-2">Cancel</a>
            </EditForm>
        }
    </div>
</div>

@code {
    private CreateUserModel model = new();
    private string[] errors = [];
    private bool created;
    private string? actorEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";
    }

    private async Task CreateAsync()
    {
        var baseUrl = Nav.BaseUri.TrimEnd('/');
        var (success, errs) = await UserService.CreateUserAsync(
            new UserParams(
                FullName: model.FullName,
                Email: model.Email,
                Phone: model.Phone,
                Addresses: model.Addresses.Select(a => new AddressParams(a.StreetAddress, a.City, a.State, a.Zip, a.IsPrivate)).ToList()), baseUrl);

        if (success)
        {
            await AuditService.LogAsync(AuditAction.CreateUser, actorEmail!, null, new Dictionary<string, string>
            {
                ["TargetEmail"] = model.Email,
                ["TargetName"] = model.FullName
            });
            created = true;
        }
        else
        {
            errors = errs;
        }
    }

    private sealed class CreateUserModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FullName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        public string Phone { get; set; } = "";

        public List<AddressModel> Addresses { get; set; } = [new()];
    }

    private sealed class AddressModel
    {
        public string StreetAddress { get; set; } = "";
        public string City { get; set; } = "";
        public string State { get; set; } = "";
        public string Zip { get; set; } = "";
        public bool IsPrivate { get; set; }
    }
}
