@page "/admin/events/create"
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject EventService EventService
@inject AuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Create Event</PageTitle>

<div class="card">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Create Event</RadzenText>

        <EditForm Model="model" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="rz-mb-6">
                <label class="form-label" for="event-name">Name</label>
                <InputText id="event-name" class="form-control" @bind-Value="model.Name" />
            </div>

            <div class="rz-mb-6">
                <label class="form-label">Description</label>
                <RadzenHtmlEditor @bind-Value="model.Description" style="height: 250px;">
                    <RadzenHtmlEditorUndo />
                    <RadzenHtmlEditorRedo />
                    <RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorBold />
                    <RadzenHtmlEditorItalic />
                    <RadzenHtmlEditorUnderline />
                    <RadzenHtmlEditorStrikeThrough />
                    <RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorUnorderedList />
                    <RadzenHtmlEditorOrderedList />
                    <RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorColor />
                    <RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorLink />
                    <RadzenHtmlEditorUnlink />
                    <RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorSource />
                </RadzenHtmlEditor>
            </div>

            <div class="rz-mb-6">
                <label class="form-label" for="event-location">Location</label>
                <InputText id="event-location" class="form-control" @bind-Value="model.Location" />
            </div>

            <div class="row rz-mb-6">
                <div class="col-md-4">
                    <label class="form-label" for="event-date">Date</label>
                    <InputDate id="event-date" class="form-control" @bind-Value="model.Date" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="event-time">Time</label>
                    <InputDate id="event-time" Type="InputDateType.Time" class="form-control" @bind-Value="model.Time" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="event-duration">Duration (hours)</label>
                    <InputNumber id="event-duration" class="form-control" @bind-Value="model.DurationHours" />
                </div>
            </div>

            <div class="rz-mb-6 form-check">
                <InputCheckbox id="event-public" class="form-check-input" @bind-Value="model.IsPublic" />
                <label class="form-check-label" for="event-public">Public event (visible on home page)</label>
            </div>

            <div class="rz-mb-6 form-check">
                <InputCheckbox id="event-rsvp" class="form-check-input" @bind-Value="model.RequiresRsvp" />
                <label class="form-check-label" for="event-rsvp">Require RSVP</label>
            </div>

            <RadzenButton ButtonType="ButtonType.Submit" Text="Create Event" ButtonStyle="ButtonStyle.Primary" />
            <a href="/admin/events" class="rz-ms-2"><RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Secondary" /></a>
        </EditForm>
    </div>
</div>

@code {
    private EventModel model = new();

    private async Task CreateAsync()
    {
        var dateTime = model.Date.Add(model.Time.TimeOfDay);
        var duration = TimeSpan.FromHours(model.DurationHours);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";

        var evt = await EventService.CreateAsync(
            new EventParams(
                Name: model.Name,
                Description: model.Description ?? "",
                Date: dateTime,
                Duration: duration,
                Location: model.Location,
                IsPublic: model.IsPublic,
                RequiresRsvp: model.RequiresRsvp),
            actorEmail);

        await AuditService.LogAsync(AuditAction.CreateEvent, actorEmail, null, new Dictionary<string, string>
        {
            ["EventName"] = evt.Name,
            ["EventId"] = evt.Id.ToString()
        });

        Nav.NavigateTo("/admin/events");
    }

    private sealed class EventModel
    {
        [Required]
        public string Name { get; set; } = "";

        public string? Description { get; set; } = "";

        public DateTime Date { get; set; } = DateTime.Today;

        public DateTime Time { get; set; } = DateTime.Today.AddHours(18);

        [Required]
        [Range(0.25, 72, ErrorMessage = "Duration must be between 15 minutes and 72 hours.")]
        public double DurationHours { get; set; } = 1;

        public string? Location { get; set; }
        public bool IsPublic { get; set; }
        public bool RequiresRsvp { get; set; }
    }
}
