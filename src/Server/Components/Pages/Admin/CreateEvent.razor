@page "/admin/events/create"
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]

@inject EventService EventService
@inject AuditService AuditService
@inject NavigationManager Nav

<PageTitle>Create Event</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Create Event</h1>

        <EditForm Model="model" OnValidSubmit="CreateAsync" FormName="createEvent">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="model.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="5" @bind-Value="model.Description" />
                <div class="form-text">Basic HTML is allowed: links, bold, italic, and lists.</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Location</label>
                <InputText class="form-control" @bind-Value="model.Location" />
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Date</label>
                    <InputDate class="form-control" @bind-Value="model.Date" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Time</label>
                    <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="model.Time" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Duration (hours)</label>
                    <InputNumber class="form-control" @bind-Value="model.DurationHours" />
                </div>
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="model.IsPublic" />
                <label class="form-check-label">Public event (visible on home page)</label>
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="model.RequiresRsvp" />
                <label class="form-check-label">Require RSVP</label>
            </div>

            <button type="submit" class="btn btn-primary">Create Event</button>
            <a href="/admin/events" class="btn btn-secondary ms-2">Cancel</a>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private EventModel? model { get; set; }

    protected override void OnInitialized() => model ??= new();

    private async Task CreateAsync()
    {
        var dateTime = model.Date.Add(model.Time.TimeOfDay);
        var duration = TimeSpan.FromHours(model.DurationHours);
        var actorEmail = HttpContext.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";

        var evt = await EventService.CreateAsync(
            model.Name, model.Description, dateTime, duration,
            model.Location, model.IsPublic, model.RequiresRsvp, actorEmail);

        var ip = HttpContext.Connection.RemoteIpAddress?.ToString();
        await AuditService.LogAsync(AuditAction.CreateEvent, actorEmail, ip, new Dictionary<string, string>
        {
            ["EventName"] = evt.Name,
            ["EventId"] = evt.Id.ToString()
        });

        Nav.NavigateTo("/admin/events");
    }

    private sealed class EventModel
    {
        [Required]
        public string Name { get; set; } = "";

        [Required]
        public string Description { get; set; } = "";

        public DateTime Date { get; set; } = DateTime.Today;

        public DateTime Time { get; set; } = DateTime.Today.AddHours(18);

        [Required]
        [Range(0.25, 72, ErrorMessage = "Duration must be between 15 minutes and 72 hours.")]
        public double DurationHours { get; set; } = 1;

        public string? Location { get; set; }
        public bool IsPublic { get; set; }
        public bool RequiresRsvp { get; set; }
    }
}
