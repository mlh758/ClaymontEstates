@page "/admin/emergency-contacts"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]

@inject UserService UserService
@inject EmergencyContactService ContactService

<PageTitle>Manage Emergency Contacts</PageTitle>

<div class="card">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Manage Emergency Contacts</RadzenText>

        @if (users is null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell class="hide-narrow">Address</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell class="hide-narrow">Contacts</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell></RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var user in users)
                    {
                        <RadzenTableRow>
                            <RadzenTableCell><a href="/admin/users/@user.Id">@user.FullName</a></RadzenTableCell>
                            <RadzenTableCell class="hide-narrow">@user.AddressDisplay(true)</RadzenTableCell>
                            <RadzenTableCell class="hide-narrow">@(contactCounts.GetValueOrDefault(user.Id))</RadzenTableCell>
                            <RadzenTableCell>
                                <a href="/admin/emergency-contacts/@user.Id"><RadzenButton Text="Manage" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<ApplicationUser>? users;
    private Dictionary<string, int> contactCounts = new();

    protected override async Task OnInitializedAsync()
    {
        users = await UserService.GetAllUsersWithRolesAsync();
        contactCounts = await ContactService.GetCountsByUserAsync();
    }
}
