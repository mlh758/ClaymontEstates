@page "/admin/events"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]

@inject EventService EventService

<PageTitle>Manage Events</PageTitle>

<div class="card">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Manage Events</RadzenText>

        <a href="/admin/events/create" class="rz-mb-4 rz-display-inline-block"><RadzenButton Text="Create Event" ButtonStyle="ButtonStyle.Primary" /></a>

        @if (events is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (events.Count == 0)
        {
            <p class="rz-mb-0">No events in the last 30 days or next 90 days.</p>
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Date</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Duration</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell></RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var evt in events)
                    {
                        var isPast = evt.Date.Add(evt.Duration) < DateTime.UtcNow;
                        <RadzenTableRow Style="@(isPast ? "color: var(--rz-secondary)" : "")">
                            <RadzenTableCell>@evt.Name</RadzenTableCell>
                            <RadzenTableCell>@evt.Date.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</RadzenTableCell>
                            <RadzenTableCell>@FormatDuration(evt.Duration)</RadzenTableCell>
                            <RadzenTableCell>
                                <a href="/admin/events/edit/@evt.Id"><RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                                @if (evt.RequiresRsvp)
                                {
                                    <a href="/admin/events/@evt.Id/attendees" class="rz-ms-1"><RadzenButton Text="Attendees" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                                }
                            </RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetRecentAndUpcomingAsync();
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalMinutes < 60)
            return $"{(int)duration.TotalMinutes}m";
        if (duration.Minutes == 0)
            return $"{(int)duration.TotalHours}h";
        return $"{(int)duration.TotalHours}h {duration.Minutes}m";
    }
}
