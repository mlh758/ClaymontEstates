@page "/admin/documents/upload"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer

@inject DocumentService DocumentService
@inject AuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Upload Document</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Upload Document</h1>

        @if (!string.IsNullOrEmpty(message))
        {
            <RadzenAlert AlertStyle="@(isError ? AlertStyle.Danger : AlertStyle.Success)" AllowClose="false" ShowIcon="false">@message</RadzenAlert>
        }

        @if (uploaded)
        {
            <a href="/documents" class="btn btn-secondary">Back to Documents</a>
        }
        else
        {
            <EditForm Model="model" OnValidSubmit="UploadAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="model.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description (optional)</label>
                    <InputTextArea class="form-control" @bind-Value="model.Description" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Effective Date</label>
                    <InputDate class="form-control" @bind-Value="model.EffectiveDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">File (max 50 MB)</label>
                    <InputFile OnChange="OnFileSelected" class="form-control" />
                </div>

                @if (selectedFile is not null)
                {
                    <p class="text-muted">Selected: @selectedFile.Name (@FormatSize(selectedFile.Size))</p>
                }

                <button type="submit" class="btn btn-primary" disabled="@(selectedFile is null || uploading)">
                    @(uploading ? "Uploading..." : "Upload")
                </button>
                <a href="/documents" class="btn btn-secondary ms-2">Cancel</a>
            </EditForm>
        }
    </div>
</div>

@code {
    private UploadModel model = new() { EffectiveDate = DateTime.Today };
    private IBrowserFile? selectedFile;
    private string? message;
    private bool isError;
    private bool uploaded;
    private bool uploading;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task UploadAsync()
    {
        if (selectedFile is null) return;

        uploading = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var actorEmail = authState.User.FindFirstValue(ClaimTypes.Email) ?? "unknown";

        await using var stream = selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        var (success, error, doc) = await DocumentService.UploadAsync(
            new DocumentUploadParams(
                Name: model.Name,
                Description: model.Description,
                EffectiveDate: model.EffectiveDate,
                UploaderEmail: actorEmail,
                FileStream: stream,
                FileName: selectedFile.Name,
                ContentType: selectedFile.ContentType,
                FileSize: selectedFile.Size));

        if (success)
        {
            await AuditService.LogAsync(AuditAction.UploadDocument, actorEmail, null, new Dictionary<string, string>
            {
                ["DocumentName"] = model.Name,
                ["FileName"] = selectedFile.Name
            });
            message = $"Document '{model.Name}' uploaded successfully.";
            isError = false;
            uploaded = true;
        }
        else
        {
            message = error;
            isError = true;
        }

        uploading = false;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private sealed class UploadModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public DateTime EffectiveDate { get; set; }
    }
}
