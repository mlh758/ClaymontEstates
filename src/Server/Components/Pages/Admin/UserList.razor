@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize(Policy = Roles.OfficerPolicy)]
@rendermode InteractiveServer
@implements IDisposable

@inject UserService UserService

<PageTitle>Manage Users</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Manage Users</h1>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="/admin/users/create" class="btn btn-primary">Create User</a>
        </div>

        <div class="mb-3">
            <input type="text" class="form-control" placeholder="Search by name or address..."
                   @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchInput" />
        </div>

        @if (users is null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Email</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Phone</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Address</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Role</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell></RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var user in users)
                    {
                        <RadzenTableRow>
                            <RadzenTableCell>@user.FullName</RadzenTableCell>
                            <RadzenTableCell>@user.Email</RadzenTableCell>
                            <RadzenTableCell>@user.PhoneNumber</RadzenTableCell>
                            <RadzenTableCell>@user.AddressDisplay(true)</RadzenTableCell>
                            <RadzenTableCell>@string.Join(", ", user.RoleNames)</RadzenTableCell>
                            <RadzenTableCell>
                                <a href="/admin/users/edit/@user.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<ApplicationUser>? users;
    private string? searchQuery;
    private Timer? debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        users = await UserService.GetAllUsersWithRolesAsync();
    }

    private void OnSearchInput()
    {
        debounceTimer?.Dispose();
        debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                users = await UserService.GetAllUsersWithRolesAsync(searchQuery);
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
    }
}
