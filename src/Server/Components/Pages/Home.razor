@page "/"
@using Server.Data
@using Server.Services
@using Server.Components.Shared

@inject EventService EventService

<PageTitle>Claymont Estates</PageTitle>

<h1>Welcome to the Claymont Estates Community Portal</h1>

<p>This is the community portal for our homeowners association. Residents can log in to view the neighborhood directory and HOA documents.</p>

<p>If you're a resident and don't have an account yet, please contact an HOA officer to get set up.</p>

@if (events is not null && events.Count > 0)
{
    <hr />
    <h2>Upcoming Events</h2>
    @foreach (var evt in events)
    {
        <EventCard Event="evt" />
    }
}

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetUpcomingPublicAsync();
    }
}
