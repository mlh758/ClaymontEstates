@page "/"
@using Server.Data
@using Server.Services
@using Server.Components.Shared

@inject EventService EventService

<PageTitle>Claymont Estates</PageTitle>

<RadzenCard Variant="Variant.Filled" class="rz-mb-6">
    <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1">Claymont Estates</RadzenText>
    <RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" style="color: var(--rz-text-secondary-color);">Resident Portal</RadzenText>

    <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-6 rz-mb-2">Log in to access the neighborhood directory, HOA documents, and community events.</RadzenText>
    <RadzenText TextStyle="TextStyle.Body1">If you're a resident and don't have an account yet, please contact an HOA officer to get set up.</RadzenText>

    <div class="home-buttons rz-mt-6">
        <a href="/directory"><RadzenButton Text="Directory" Icon="contacts" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" /></a>
        <a href="/documents"><RadzenButton Text="Documents" Icon="folder" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Large" /></a>
    </div>
</RadzenCard>

@if (events is not null && events.Count > 0)
{
    <h2>Upcoming Events</h2>
    @foreach (var evt in events)
    {
        <EventCard Event="evt" />
    }
}

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetUpcomingPublicAsync();
    }
}
