@page "/"
@using Server.Data
@using Server.Services
@using Server.Components.Shared

@inject EventService EventService

<PageTitle>Claymont Estates</PageTitle>

<div class="card mb-4">
    <div class="card-body">
        <h1 class="card-title">Claymont Estates Resident Portal</h1>
        <p class="mb-2">Log in to access the neighborhood directory, HOA documents, and community events.</p>
        <p class="mb-0">If you're a resident and don't have an account yet, please contact an HOA officer to get set up.</p>
    </div>
</div>

@if (events is not null && events.Count > 0)
{
    <h2>Upcoming Events</h2>
    @foreach (var evt in events)
    {
        <EventCard Event="evt" />
    }
}

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetUpcomingPublicAsync();
    }
}
