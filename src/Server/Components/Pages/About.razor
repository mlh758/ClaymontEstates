@page "/about"
@using Server.Data
@using Server.Services

@inject UserService UserService

<PageTitle>About</PageTitle>

<div class="card rz-mb-6">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Claymont Estates Homeowners Association</RadzenText>
        <p class="text-muted rz-mb-6">Gladstone, Missouri</p>
        <p class="rz-mb-0">
            The Claymont Estates Resident Portal provides residents with access to community documents,
            the neighborhood directory, and upcoming events.
        </p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Current Officers</h3>

        @if (officers is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (officers.Count == 0)
        {
            <p class="rz-mb-0">No officers are currently listed.</p>
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Role</RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var (name, roles) in officers)
                    {
                        <RadzenTableRow>
                            <RadzenTableCell>@name</RadzenTableCell>
                            <RadzenTableCell>@roles</RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<(string Name, string Roles)>? officers;

    protected override async Task OnInitializedAsync()
    {
        var users = await UserService.GetAllUsersWithRolesAsync();
        officers = users
            .Where(u => u.RoleNames.Any(r => Roles.OfficerRoles.Contains(r)))
            .Select(u => (
                u.FullName,
                string.Join(", ", u.RoleNames.Where(r => Roles.OfficerRoles.Contains(r)))
            ))
            .OrderBy(o => o.Item2).ThenBy(o => o.FullName)
            .ToList();
    }
}
