@page "/about"
@using Server.Data
@using Server.Services

@inject UserService UserService

<PageTitle>About</PageTitle>

<div class="card mb-4">
    <div class="card-body">
        <h1 class="card-title">Claymont Estates Homeowners Association</h1>
        <p class="text-muted mb-3">Gladstone, Missouri</p>
        <p class="mb-0">
            The Claymont Estates Resident Portal provides residents with access to community documents,
            the neighborhood directory, and upcoming events.
        </p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Current Officers</h3>

        @if (officers is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (officers.Count == 0)
        {
            <p class="mb-0">No officers are currently listed.</p>
        }
        else
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (name, roles) in officers)
                    {
                        <tr>
                            <td>@name</td>
                            <td>@roles</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<(string Name, string Roles)>? officers;

    protected override async Task OnInitializedAsync()
    {
        var users = await UserService.GetAllUsersWithRolesAsync();
        officers = users
            .Where(u => u.RoleNames.Any(r => Roles.OfficerRoles.Contains(r)))
            .Select(u => (
                u.FullName,
                string.Join(", ", u.RoleNames.Where(r => Roles.OfficerRoles.Contains(r)))
            ))
            .OrderBy(o => o.Item2).ThenBy(o => o.FullName)
            .ToList();
    }
}
