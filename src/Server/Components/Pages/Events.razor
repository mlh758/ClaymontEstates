@page "/events"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@using Server.Components.Shared
@attribute [Authorize]
@rendermode InteractiveServer

@inject EventService EventService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Events</PageTitle>

<div class="card rz-mb-6">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Events</RadzenText>
        <div class="d-flex align-items-center" style="gap: calc(var(--spacing) * 6)">
            <RadzenButton Text="« Previous" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="PreviousMonth" />
            <h4>@currentMonth.ToString("MMMM yyyy")</h4>
            <RadzenButton Text="Next »" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="NextMonth" />
        </div>
    </div>
</div>

@if (events is null)
{
    <p><em>Loading...</em></p>
}
else if (events.Count == 0)
{
    <p>No events this month.</p>
}
else
{
    @foreach (var summary in events)
    {
        <EventCard Event="summary.Event">
            @if (summary.Event.RequiresRsvp)
            {
                var attending = userRsvpEventIds.Contains(summary.Event.Id);
                <div class="d-flex align-items-center" style="gap: calc(var(--spacing) * 2)">
                    <span class="text-muted">@summary.RsvpCount attending</span>
                    @if (attending)
                    {
                        <RadzenBadge Text="You're going" BadgeStyle="BadgeStyle.Success" />
                        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" Size="ButtonSize.Small" Click="() => CancelRsvpAsync(summary)" />
                    }
                    else
                    {
                        <RadzenButton Text="RSVP" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="() => RsvpAsync(summary)" />
                    }
                </div>
            }
        </EventCard>
    }
}

@code {
    private DateTime currentMonth;
    private List<EventSummary>? events;
    private HashSet<int> userRsvpEventIds = [];
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        var from = currentMonth;
        var to = currentMonth.AddMonths(1);

        events = await EventService.GetEventsForMonthAsync(currentMonth);

        if (currentUserId is not null)
            userRsvpEventIds = await EventService.GetUserRsvpEventIdsAsync(currentUserId, from, to);
    }

    private async Task PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
        await LoadEventsAsync();
    }

    private async Task NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
        await LoadEventsAsync();
    }

    private async Task RsvpAsync(EventSummary summary)
    {
        if (currentUserId is null) return;
        var (success, _) = await EventService.RsvpAsync(summary.Event.Id, currentUserId);
        if (success)
        {
            userRsvpEventIds.Add(summary.Event.Id);
            summary.RsvpCount++;
        }
    }

    private async Task CancelRsvpAsync(EventSummary summary)
    {
        if (currentUserId is null) return;
        var (success, _) = await EventService.CancelRsvpAsync(summary.Event.Id, currentUserId);
        if (success)
        {
            userRsvpEventIds.Remove(summary.Event.Id);
            summary.RsvpCount--;
        }
    }
}
