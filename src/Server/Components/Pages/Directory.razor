@page "/directory"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Directory</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Resident Directory</h1>

        <div class="mb-3">
            <input type="text" class="form-control" placeholder="Search by name or address..."
                   @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchInput" />
        </div>

        <RadzenMediaQuery Query="(max-width: 768px)" Change="@(matches => isMobile = matches)" />

        @if (residents is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (residents.Count == 0)
        {
            <p class="mb-0">No residents found.</p>
        }
        else if (isMobile)
        {
            @foreach (var (resident, role) in residents)
            {
                var showPrivate = isOfficerOrAbove || resident.ShowContactInfo;
                <RadzenCard class="mb-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="mb-0 mt-0 text-lg">@resident.FullName</h5>
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@role" />
                        }
                    </div>
                    <p class="mb-1 text-muted">@resident.StreetAddress</p>
                    @if (showPrivate)
                    {
                        @if (!string.IsNullOrEmpty(resident.Email))
                        {
                            <p class="mb-1"><strong>Email:</strong> @resident.Email</p>
                        }
                        @if (!string.IsNullOrEmpty(resident.PhoneNumber))
                        {
                            <p class="mb-0"><strong>Phone:</strong> @resident.PhoneNumber</p>
                        }
                    }
                </RadzenCard>
            }
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Role</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Address</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Email</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Phone</RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var (resident, role) in residents)
                    {
                        var showPrivate = isOfficerOrAbove || resident.ShowContactInfo;
                        <RadzenTableRow>
                            <RadzenTableCell>@resident.FullName</RadzenTableCell>
                            <RadzenTableCell>@(role ?? "")</RadzenTableCell>
                            <RadzenTableCell>@resident.StreetAddress</RadzenTableCell>
                            <RadzenTableCell>@(showPrivate ? resident.Email : "—")</RadzenTableCell>
                            <RadzenTableCell>@(showPrivate ? resident.PhoneNumber : "—")</RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<(ApplicationUser User, string? DisplayRoles)>? residents;
    private string? searchQuery;
    private bool isOfficerOrAbove;
    private bool isMobile;
    private Timer? debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isOfficerOrAbove = Roles.OfficerRoles.Any(r => user.IsInRole(r));

        residents = await UserService.SearchUsersWithRolesAsync(null);
    }

    private void OnSearchInput()
    {
        debounceTimer?.Dispose();
        debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                residents = await UserService.SearchUsersWithRolesAsync(searchQuery);
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
    }
}
