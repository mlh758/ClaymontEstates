@page "/directory"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize]
@rendermode InteractiveServer

@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Directory</PageTitle>

<h1>Resident Directory</h1>

<div class="mb-3">
    <input type="text" class="form-control" placeholder="Search by name or address..."
           @bind="searchQuery" @bind:event="oninput" @bind:after="SearchAsync" />
</div>

@if (residents is null)
{
    <p><em>Loading...</em></p>
}
else if (residents.Count == 0)
{
    <p>No residents found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Address</th>
                <th>Email</th>
                <th>Phone</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (resident, role) in residents)
            {
                var showPrivate = isOfficerOrAbove || resident.ShowContactInfo;
                <tr>
                    <td>@resident.FullName</td>
                    <td>@(role ?? "")</td>
                    <td>@resident.StreetAddress</td>
                    <td>@(showPrivate ? resident.Email : "—")</td>
                    <td>@(showPrivate ? resident.PhoneNumber : "—")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<(ApplicationUser User, string? Role)>? residents;
    private string? searchQuery;
    private bool isOfficerOrAbove;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isOfficerOrAbove = Roles.OfficerRoles.Any(r => user.IsInRole(r));

        residents = await UserService.SearchUsersWithRolesAsync(null);
    }

    private async Task SearchAsync()
    {
        residents = await UserService.SearchUsersWithRolesAsync(searchQuery);
    }
}
