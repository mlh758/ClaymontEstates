@page "/directory"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Directory</PageTitle>

<div class="card">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Resident Directory</RadzenText>

        @if (isOfficerOrAbove)
        {
            <div class="rz-mb-4 d-flex flex-wrap align-items-center" style="gap: calc(var(--spacing) * 2)">
                <RadzenDropDown @bind-Value="envelopeSize" Data="EnvelopeService.Sizes"
                                TextProperty="Label" ValueProperty="Key" Style="min-width: 14rem;" />
                <a href="@($"/api/directory/envelopes/outgoing?size={envelopeSize}")" target="_blank" rel="noopener">
                    <RadzenButton Text="Mailing Envelopes" Icon="mail" ButtonStyle="ButtonStyle.Secondary" />
                </a>
                <a href="@($"/api/directory/envelopes/return?size={envelopeSize}")" target="_blank" rel="noopener">
                    <RadzenButton Text="Return Envelopes" Icon="undo" ButtonStyle="ButtonStyle.Secondary" />
                </a>
            </div>
        }

        <div class="rz-mb-6">
            <input type="text" class="form-control" placeholder="Search by name or address..."
                   @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchInput" />
        </div>

        <RadzenMediaQuery Query="(max-width: 768px)" Change="@(matches => isMobile = matches)" />

        @if (residents is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (residents.Count == 0)
        {
            <p class="rz-mb-0">No residents found.</p>
        }
        else if (isMobile)
        {
            @foreach (var (resident, role) in residents)
            {
                var showPrivate = isOfficerOrAbove || resident.ShowContactInfo;
                <RadzenCard class="rz-mb-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="rz-mb-0 rz-mt-0 text-lg">@resident.FullName</h5>
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@role" />
                        }
                    </div>
                    @foreach (var address in (resident.Addresses ?? []).Where(a => isOfficerOrAbove || !a.IsPrivate))
                    {
                        <p class="rz-mb-1 text-muted">@address.StreetAddress</p>
                    }
                    @if (showPrivate)
                    {
                        @if (!string.IsNullOrEmpty(resident.Email))
                        {
                            <p class="rz-mb-1"><strong>Email:</strong> <a href="mailto:@resident.Email">@resident.Email</a></p>
                        }
                        @if (!string.IsNullOrEmpty(resident.PhoneNumber))
                        {
                            <p class="rz-mb-0"><strong>Phone:</strong> <a href="tel:@resident.PhoneNumber">@resident.PhoneNumber</a></p>
                        }
                    }
                </RadzenCard>
            }
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Role</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Address</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Email</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Phone</RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var (resident, role) in residents)
                    {
                        var showPrivate = isOfficerOrAbove || resident.ShowContactInfo;
                        var visibleAddresses = (resident.Addresses ?? []).Where(a => isOfficerOrAbove || !a.IsPrivate).ToList();
                        var rowCount = Math.Max(visibleAddresses.Count, 1);
                        <RadzenTableRow>
                            <RadzenTableCell rowspan="@rowCount" style="vertical-align: middle;">@resident.FullName</RadzenTableCell>
                            <RadzenTableCell rowspan="@rowCount" style="vertical-align: middle;">@(role ?? "")</RadzenTableCell>
                            <RadzenTableCell>@(visibleAddresses.ElementAtOrDefault(0)?.StreetAddress ?? "")</RadzenTableCell>
                            <RadzenTableCell rowspan="@rowCount" style="vertical-align: middle;">@if (showPrivate && !string.IsNullOrEmpty(resident.Email)) { <a href="mailto:@resident.Email">@resident.Email</a> } else { <text>—</text> }</RadzenTableCell>
                            <RadzenTableCell rowspan="@rowCount" style="vertical-align: middle;">@if (showPrivate && !string.IsNullOrEmpty(resident.PhoneNumber)) { <a href="tel:@resident.PhoneNumber">@resident.PhoneNumber</a> } else { <text>—</text> }</RadzenTableCell>
                        </RadzenTableRow>
                        @foreach (var extra in visibleAddresses.Skip(1))
                        {
                            <RadzenTableRow>
                                <RadzenTableCell>@extra.StreetAddress</RadzenTableCell>
                            </RadzenTableRow>
                        }
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<(ApplicationUser User, string? DisplayRoles)>? residents;
    private string? searchQuery;
    private bool isOfficerOrAbove;
    private string envelopeSize = EnvelopeService.Number10.Key;
    private bool isMobile;
    private Timer? debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isOfficerOrAbove = Roles.OfficerRoles.Any(r => user.IsInRole(r));

        residents = await UserService.SearchUsersWithRolesAsync(null);
    }

    private void OnSearchInput()
    {
        debounceTimer?.Dispose();
        debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                residents = await UserService.SearchUsersWithRolesAsync(searchQuery);
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
    }
}
