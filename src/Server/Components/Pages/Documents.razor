@page "/documents"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize]

@inject DocumentService DocumentService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Documents</PageTitle>

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Documents</h1>

        <AuthorizeView Policy="@Roles.OfficerPolicy">
            <Authorized>
                <a href="/admin/documents/upload" class="btn btn-primary mb-3">Upload Document</a>
            </Authorized>
        </AuthorizeView>

        @if (documents is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (documents.Count == 0)
        {
            <p class="mb-0">No documents have been uploaded yet.</p>
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Description</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Effective Date</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Uploaded By</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell></RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var doc in documents)
                    {
                        <RadzenTableRow>
                            <RadzenTableCell>@doc.Name</RadzenTableCell>
                            <RadzenTableCell>@(doc.Description ?? "")</RadzenTableCell>
                            <RadzenTableCell>@doc.EffectiveDate.ToString("yyyy-MM-dd")</RadzenTableCell>
                            <RadzenTableCell>@doc.UploadedByEmail</RadzenTableCell>
                            <RadzenTableCell>
                                <a href="/api/documents/@doc.Id/download" class="btn btn-sm btn-outline-primary">Download</a>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<Document>? documents;

    protected override async Task OnInitializedAsync()
    {
        documents = await DocumentService.GetAllAsync();
    }
}
