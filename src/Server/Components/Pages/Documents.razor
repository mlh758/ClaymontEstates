@page "/documents"
@using Microsoft.AspNetCore.Authorization
@using Server.Data
@using Server.Services
@attribute [Authorize]
@rendermode InteractiveServer

@inject DocumentService DocumentService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Documents</PageTitle>

<div class="card">
    <div class="card-body">
        <RadzenText TextStyle="TextStyle.H1" TagName="TagName.H1" class="card-title">Documents</RadzenText>

        <AuthorizeView Policy="@Roles.OfficerPolicy">
            <Authorized>
                <a href="/admin/documents/upload" class="rz-mb-6"><RadzenButton Text="Upload Document" ButtonStyle="ButtonStyle.Primary" /></a>
            </Authorized>
        </AuthorizeView>

        <RadzenMediaQuery Query="(max-width: 768px)" Change="@(matches => isMobile = matches)" />

        @if (documents is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (documents.Count == 0)
        {
            <p class="rz-mb-0">No documents have been uploaded yet.</p>
        }
        else if (isMobile)
        {
            @foreach (var doc in documents)
            {
                <RadzenCard class="rz-mb-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="rz-mb-0 rz-mt-0 text-lg">@doc.Name</h5>
                        <div>
                            <AuthorizeView Policy="@Roles.OfficerPolicy">
                                <Authorized>
                                    <a href="/admin/documents/edit/@doc.Id" class="rz-me-1"><RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                                </Authorized>
                            </AuthorizeView>
                            <a href="/api/documents/@doc.Id/download"><RadzenButton Text="Download" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(doc.Description))
                    {
                        <p class="rz-mb-1 text-muted">@doc.Description</p>
                    }
                    <p class="rz-mb-1"><strong>Effective:</strong> @doc.EffectiveDate.ToString("yyyy-MM-dd")</p>
                    <p class="rz-mb-0 text-muted"><small>Uploaded by @doc.UploadedByEmail</small></p>
                </RadzenCard>
            }
        }
        else
        {
            <RadzenTable>
                <RadzenTableHeader>
                    <RadzenTableHeaderRow>
                        <RadzenTableHeaderCell>Name</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Description</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Effective Date</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell>Uploaded By</RadzenTableHeaderCell>
                        <RadzenTableHeaderCell></RadzenTableHeaderCell>
                    </RadzenTableHeaderRow>
                </RadzenTableHeader>
                <RadzenTableBody>
                    @foreach (var doc in documents)
                    {
                        <RadzenTableRow>
                            <RadzenTableCell>@doc.Name</RadzenTableCell>
                            <RadzenTableCell>@(doc.Description ?? "")</RadzenTableCell>
                            <RadzenTableCell>@doc.EffectiveDate.ToString("yyyy-MM-dd")</RadzenTableCell>
                            <RadzenTableCell>@doc.UploadedByEmail</RadzenTableCell>
                            <RadzenTableCell>
                                <AuthorizeView Policy="@Roles.OfficerPolicy">
                                    <Authorized>
                                        <a href="/admin/documents/edit/@doc.Id" class="rz-me-1"><RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                                    </Authorized>
                                </AuthorizeView>
                                <a href="/api/documents/@doc.Id/download"><RadzenButton Text="Download" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Outlined" Size="ButtonSize.Small" /></a>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    }
                </RadzenTableBody>
            </RadzenTable>
        }
    </div>
</div>

@code {
    private List<Document>? documents;
    private bool isMobile;

    protected override async Task OnInitializedAsync()
    {
        documents = await DocumentService.GetAllAsync();
    }
}
